{
  "manifest_version": 3,
  "name": "Paperless-ngx Uploader",
  "version": "1.0.0",
  "description": "Upload PDF attachments directly to Paperless-ngx from Thunderbird",
  "browser_specific_settings": {
    "gecko": {
      "id": "@paperless-uploader.sebastian-xyz",
      "strict_min_version": "140.0"
    }
  },
  "permissions": [
    "messagesRead",
    "menus",
    "notifications",
    "storage"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "message_display_action": {
    "default_title": "Paperless PDF Uploader",
    "default_popup": "message-display-popup.html",
    "default_icon": "icons/icon-32.png"
  },
  "action": {
    "default_title": "Paperless PDF Uploader",
    "default_popup": "popup.html",
    "default_icon": "icons/icon-32.png"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "icons": {
    "128": "icons/icon-128.png",
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self';"
  }
}
